# Copia este archivo como .env y ajusta los valores.

# Base de datos PostgreSQL.
# Local: puedes usar un Postgres local o el mismo Postgres en la nube (Neon/Render).
# Ejemplo Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://usuario:password@host:5432/hotel?sslmode=require"

# Secreto para firmar la cookie de sesión del panel. Usa un valor aleatorio largo.
SESSION_SECRET="cambia-esto-por-un-secreto-aleatorio-largo"
