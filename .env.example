# Copia este archivo como .env y ajusta los valores.

# Base de datos. SQLite por defecto (local). Para Vercel usar Postgres (Neon).
DATABASE_URL="file:./dev.db"

# Secreto para firmar la cookie de sesión del panel. Usa un valor aleatorio largo.
SESSION_SECRET="cambia-esto-por-un-secreto-aleatorio-largo"
